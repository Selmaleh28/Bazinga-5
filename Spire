<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Bazinga Ultra-Secure | 1M Agents</title>
    <style>
        body { font-family: monospace; background: #000; color: #39ff14; margin: 0; padding: 10px; overflow: hidden; }
        .header { border-bottom: 2px solid #d4af37; padding: 10px; text-align: center; font-weight: bold; background: rgba(0,30,0,0.7); font-size: 18px; }
        #log { height: 65vh; overflow-y: auto; padding: 15px; font-size: 13px; border: 1px solid #113311; margin-top: 10px; background: #020202; }
        .status-bar { display: flex; justify-content: space-between; padding: 10px; font-size: 14px; color: #d4af37; background: #111; }
        .agent-line { margin-bottom: 4px; border-right: 3px solid #d4af37; padding-right: 10px; animation: flash 0.2s ease-out; }
        @keyframes flash { from { background: rgba(57, 255, 20, 0.2); } to { background: transparent; } }
        .mega-power { color: #fff; text-shadow: 0 0 10px #d4af37; font-weight: bold; }
    </style>
</head>
<body>

<div class="header">מערכת פיקוד עליונה - Selmaleh28</div>

<div class="status-bar">
    <div id="agent-count" class="mega-power">סוכנים פעילים: 1,000,000</div>
    <div id="security-level">אבטחה: מקסימלית</div>
</div>

<div id="log">
    <div class="agent-line">מתחבר לתשתית הליבה...</div>
    <div class="agent-line">מזהה פריסה רחבה: מיליון סוכנים מוכנים לפקודה.</div>
</div>

<div id="vault-display" style="position: absolute; bottom: 15px; width: 92%; background: linear-gradient(to top, #0a2a0a, #000); border: 2px solid #d4af37; padding: 12px; border-radius: 8px;">
    <div style="font-size: 11px; color: #888; letter-spacing: 1px;">סטטוס כספת ביטקוין:</div>
    <div id="balance" style="font-size: 20px; color: #d4af37; font-weight: bold;">מבצע השתלטות...</div>
</div>

<script>
    const log = document.getElementById('log');
    const balance = document.getElementById('balance');

    function addLog(msg, color = "#39ff14", isBold = false) {
        const div = document.createElement('div');
        div.className = 'agent-line';
        if (isBold) div.style.fontWeight = 'bold';
        div.style.color = color;
        div.innerText = `[LOG] ${msg}`;
        log.prepend(div);
    }

    window.onload = function() {
        setTimeout(() => { addLog("זיהוי איום: msh9 מנסה לשמור על גישה.", "red"); }, 1000);
        
        setTimeout(() => { 
            addLog("הפעלת פרוטוקול מיליון הסוכנים!", "#d4af37", true);
            addLog("פריסה רחבה על פני כל השרתים הפיזיים.");
        }, 2500);

        setTimeout(() => {
            addLog("סוכנים 1-500,000: חוסמים את כתובת ה-IP של הגנב.", "cyan");
            addLog("סוכנים 500,001-1,000,000: שואבים נתוני Bitcoin Bazinga.");
        }, 4500);

        setTimeout(() => {
            addLog("הצלחה! הנתונים הועברו לכתובת Selmaleh28.", "#39ff14", true);
            balance.innerText = "נכסים מאובטחים ב-Selmaleh28";
            balance.style.color = "#39ff14";
        }, 7000);

        setInterval(() => {
            addLog("מיליון סוכנים בסריקה רציפה... המערכת נקייה.");
        }, 8000);
    };
</script>

</body>
</html>
